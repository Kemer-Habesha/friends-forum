# Build/runtime artefacts that should never enter the build context
node_modules
.next
out

# Source control / CI metadata
.git
.gitignore
.github

# Editor / OS noise
.vscode
.idea
.DS_Store
Thumbs.db

# Local env files (secrets must come in via Cloud Build substitutions, never the image)
.env
.env.local
.env
.env.development.local
.env.test.local
.env.production.local

# Logs and TS incremental cache
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tsbuildinfo

# Docs and infra files that don't need to be in the build context
README.md
Dockerfile
.dockerignore
cloudbuild.yaml
